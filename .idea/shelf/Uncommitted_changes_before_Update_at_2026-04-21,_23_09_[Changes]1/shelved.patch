<+>server:\n  port: 8080\n\nspring:\n  datasource:\n    url: jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3306}/${DB_NAME:smartcampus}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC\n    username: ${DB_USER:root}\n    password: ${DB_PASSWORD:password}\n    driver-class-name: com.mysql.cj.jdbc.Driver\n\n  jpa:\n    hibernate:\n      ddl-auto: update\n    properties:\n      hibernate:\n        dialect: org.hibernate.dialect.MySQL8Dialect\n        format_sql: true\n    open-in-view: false\n\n  jackson:\n    serialization:\n      write-dates-as-timestamps: false\n\nlogging:\n  level:\n    org.hibernate.SQL: INFO\n\n# Cross-origin browser access when the SPA origin differs from the API (e.g. VITE_API_BASE_URL set).\n# Prefer same-origin /api + Vite proxy in dev to avoid CORS entirely. Override via env, e.g.:\n# APP_CORS_ALLOWED_ORIGIN_PATTERNS_0=http://localhost:*\n# APP_CORS_ALLOWED_ORIGIN_PATTERNS_1=http://192.168.1.10:*\napp:\n  security:\n    # Bootstrap admin when no ADMIN exists (override via ADMIN_USERNAME / ADMIN_PASSWORD in production).\n    bootstrap-admin-username: ${ADMIN_USERNAME:admin}\n    bootstrap-admin-password: ${ADMIN_PASSWORD:admin123}\n  cors:\n    allowed-origin-patterns:\n      - http://localhost:*\n      - http://127.0.0.1:*\n      - http://[::1]:*\n      - \"*\"\n
